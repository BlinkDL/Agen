(s=Гҳ) вһң s=[[0, {len(a)-1}]]
(phase=в– , pivot=в—Ҷ, lo=в—Җ, hi=в–¶, i=в–І, j=в–ј)
    (в– =i)
        (a.в–І<в—Ҷ) вһң в–І+=1
        в– =j
    (в– =j)
        (a.в–ј>в—Ҷ) вһң в–ј-=1
        (в–І<в–ј) вһң a.в–І,a.в–ј={a.в–ј},{a.в–І}, в–І+=1, в–ј-=1, в– =i
        s+=[[в—Җ, в–ј], [{в–ј+1}, в–¶]]
        в—Җ=Гҳ, в– =Гҳ
    (в—Җ, в—Җ<в–¶) вһң в–І=в—Җ, в–ј=в–¶, в—Ҷ={a.{(в–І+в–ј)//2}}, в– =i
    ({len(s)}>0) вһң [в—Җ, в–¶]={s.pop()}
